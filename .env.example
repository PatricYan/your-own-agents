# AgentPipe Configuration
# Copy to .env and edit. Used by both local and Docker runs.

# === Server ===
AGENTPIPE_HOST=0.0.0.0
AGENTPIPE_PORT=8420
AGENTPIPE_LOG_LEVEL=info

# === Frontend ===
REACT_APP_API_URL=http://localhost:8420

# === Model API Keys ===
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# === Ollama ===
OLLAMA_BASE_URL=http://localhost:11434
